---
// src/components/Contact.astro
---
<section id="contact" class="py-32 bg-[#fcfcfc] border-t border-slate-100">
  <div class="max-w-6xl mx-auto px-6">
    
    <div class="mb-16">
      <p class="text-[11px] tracking-[0.3em] text-[#3aa693] font-bold uppercase mb-4">
        05 — Contact
      </p>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight mb-4">
        Get In Touch
      </h2>
      <p class="text-slate-500 font-light">Based in Hanoi, Vietnam</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-16">
      
      <div class="md:col-span-7">
        <form 
          action="https://formspree.io/f/xbdzgvoo" 
          method="POST" 
          class="flex flex-col gap-10"
        >
          <div class="flex flex-col gap-2">
            <label for="name" class="text-[10px] tracking-[0.2em] text-slate-400 font-bold uppercase">Name</label>
            <input type="text" id="name" name="name" required placeholder="Your name" class="bg-transparent border-b border-slate-200 py-2 focus:border-[#3aa693] outline-none transition-colors text-slate-800 placeholder:text-slate-200" />
          </div>

          <div class="flex flex-col gap-2">
            <label for="email" class="text-[10px] tracking-[0.2em] text-slate-400 font-bold uppercase">Email</label>
            <input type="email" id="email" name="_replyto" required placeholder="Your email" class="bg-transparent border-b border-slate-200 py-2 focus:border-[#3aa693] outline-none transition-colors text-slate-800 placeholder:text-slate-200" />
          </div>

          <div class="flex flex-col gap-2">
            <label for="message" class="text-[10px] tracking-[0.2em] text-slate-400 font-bold uppercase">Message</label>
            <textarea id="message" name="message" required rows="4" placeholder="How can I help you?" class="bg-transparent border-b border-slate-200 py-2 focus:border-[#3aa693] outline-none transition-colors text-slate-800 resize-none placeholder:text-slate-200"></textarea>
          </div>

          <button type="submit" class="w-fit px-10 py-3 bg-[#3aa693] hover:bg-[#2d8576] text-white font-medium transition-all duration-300">
            Send Message
          </button>
        </form>
      </div>

      <div class="md:col-span-5 flex flex-col gap-10">
        <div class="flex flex-col gap-2">
          <p class="text-[10px] tracking-[0.2em] text-slate-400 font-bold uppercase">Email</p>
          <a href="mailto:dinhthit25@gmail.com" class="text-[#3aa693] hover:text-[#2d8576] transition-colors text-lg">
            dinhthit25@gmail.com
          </a>
        </div>

        <div class="flex flex-col gap-2">
          <p class="text-[10px] tracking-[0.2em] text-slate-400 font-bold uppercase">Linkedin</p>
          <a href="https://www.linkedin.com/in/thi-nguyen-dinh-6419bb370/" target="_blank" rel="noopener noreferrer" class="text-[#3aa693] hover:text-[#2d8576] transition-colors text-lg">
            Thi Nguyen Dinh
          </a>
        </div>

        <div class="flex flex-col gap-2">
          <p class="text-[10px] tracking-[0.2em] text-slate-400 font-bold uppercase">Github</p>
          <a href="https://github.com/NgyDinhThi" target="_blank" rel="noopener noreferrer" class="text-[#3aa693] hover:text-[#2d8576] transition-colors text-lg">
            NgyDinhThi
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<footer class="py-12 bg-[#fcfcfc] border-t border-slate-100 text-center">
    <p class="text-slate-400 text-[11px] tracking-widest uppercase italic">
        © {new Date().getFullYear()} Nguyen Dinh Thi · Built with Astro
    </p>
</footer>