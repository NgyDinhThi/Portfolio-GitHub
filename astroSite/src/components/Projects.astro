---
// src/components/Projects.astro
---
<section id="projects" class="py-32 bg-[#fcfcfc] border-t border-slate-100">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-20">
      <p class="text-[11px] tracking-[0.3em] text-[#3aa693] font-bold uppercase mb-4">
        03 — Projects
      </p>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight">
        MY Projects
      </h2>
    </div>

    <div class="flex flex-col border-t border-slate-200">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 py-16 border-b border-slate-200 group hover:bg-slate-50/50 transition-colors duration-300 px-4">
        <div class="md:col-span-1 text-slate-400 font-mono text-sm">01</div>
        <div class="md:col-span-3">
          <h3 class="text-xl font-bold text-slate-900 group-hover:text-[#3aa693] transition-colors">
            BIM Sync Manager
          </h3>
        </div>
        <div class="md:col-span-5">
          <p class="text-slate-500 text-sm leading-relaxed">
            A specialized integration solution designed to bridge the gap between Autodesk Revit and web platforms in real-time. Enables non-Revit users to access and manipulate building data through a web interface.
          </p>
        </div>
        <div class="md:col-span-3 flex flex-col gap-4">
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 text-[10px] border border-slate-200 text-slate-400 font-medium uppercase tracking-wider">C#</span>
            <span class="px-2 py-1 text-[10px] border border-slate-200 text-slate-400 font-medium uppercase tracking-wider">Revit API</span>
            <span class="px-2 py-1 text-[10px] border border-slate-200 text-slate-400 font-medium uppercase tracking-wider">WebSockets</span>
            <span class="px-2 py-1 text-[10px] border border-slate-200 text-slate-400 font-medium uppercase tracking-wider">Socket.IO</span>
          </div>
          <a href="#" class="text-[11px] font-bold text-[#3aa693] hover:text-[#2d8576] transition uppercase tracking-[0.2em]">
            View on GitHub →
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 py-16 border-b border-slate-200 group hover:bg-slate-50/50 transition-colors duration-300 px-4">
        <div class="md:col-span-1 text-slate-400 font-mono text-sm">02</div>
        <div class="md:col-span-3">
          <h3 class="text-xl font-bold text-slate-900 group-hover:text-[#3aa693] transition-colors">
            2D RPG Game
          </h3>
        </div>
        <div class="md:col-span-5">
          <p class="text-slate-500 text-sm leading-relaxed">
            A fully functional 2D Role-Playing Game built within the Unity engine, showcasing logic, state management, and creative game development.
          </p>
        </div>
        <div class="md:col-span-3 flex flex-col gap-4">
          <div class="flex flex-wrap gap-2">
            <span class="px-2 py-1 text-[10px] border border-slate-200 text-slate-400 font-medium uppercase tracking-wider">Unity</span>
            <span class="px-2 py-1 text-[10px] border border-slate-200 text-slate-400 font-medium uppercase tracking-wider">C#</span>
          </div>
          <a href="#" class="text-[11px] font-bold text-[#3aa693] hover:text-[#2d8576] transition uppercase tracking-[0.2em]">
            View on GitHub →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>