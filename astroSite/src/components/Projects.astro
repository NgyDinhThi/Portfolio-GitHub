---
// src/components/Projects.astro
const projects = [
  {
    no: "01",
    title: "Green Ninja",
    desc: "Dự án game Top-down hành động với hệ thống nhiệm vụ và tương tác NPC phức tạp. Tập trung vào xử lý dữ liệu Backend qua JSON/BinaryFormatter và kiến trúc code chuẩn với Singleton/Manager pattern.",
    tags: ["Unity", "C#", "Design Patterns", "JSON"],
    demo: "https://drive.google.com/file/d/1XhfOmXOpOx-iIf4pmXPFn1PT_rTqfnnM/view?usp=sharing",
  },
  {
    no: "02",
    title: "Block Adventure",
    desc: "Game puzzle casual xây dựng trên Unity, tập trung vào tối ưu hóa hiệu suất thông qua Object Pooling và quản lý trạng thái game hiệu quả. Áp dụng nguyên lý SOLID và Design Patterns để tách biệt trách nhiệm trong mã nguồn.",
    tags: ["Unity", "C#", "SOLID"],
    demo: "https://drive.google.com/file/d/1kMbJRgbXT1XkrmlcriEC1GSb3Rksq1mM/view?usp=sharing#",
  },
  {
    no: "03",
    title: "BIM Sync Manager",
    desc: "Một giải pháp tích hợp chuyên dụng giúp kết nối mô hình Revit với nền tảng web theo thời gian thực. Cho phép người dùng không cài đặt Revit vẫn có thể truy cập và tương tác với dữ liệu công trình qua giao diện web.",
    tags: ["C# (.NET)", "Revit API", "Python (Flask)", "Socket.IO"],
    demo: "https://drive.google.com/file/d/1Uge3dbiqPYUm5VwrZYvSQrNfIfjrU3ub/view?usp=sharing",
  },
];
---
<section id="projects" class="pt-20 pb-32 bg-[#fcfcfc] border-t border-slate-100 scroll-mt-24">
  <div class="max-w-6xl mx-auto px-6">

    <div class="mb-16">
      <p class="text-[11px] tracking-[0.3em] text-[#3aa693] font-bold uppercase mb-4">
        03 — Projects
      </p>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight">
        My Projects
      </h2>
    </div>

    <div>
      {projects.map((p) => (
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8 items-start py-12 border-t border-slate-100">

          <!-- Số + Tên -->
          <div class="md:col-span-4 flex items-baseline gap-5">
            <span class="text-sm font-mono text-slate-300">{p.no}</span>
            <h3 class="text-2xl font-bold text-[#3aa693]">{p.title}</h3>
          </div>

          <!-- Mô tả -->
          <div class="md:col-span-5">
            <p class="text-slate-500 text-sm font-light leading-relaxed">{p.desc}</p>
          </div>

          <!-- Tags + Demo -->
          <div class="md:col-span-3 flex flex-col gap-5">
            <div class="flex flex-wrap gap-2">
              {p.tags.map((t) => (
                <span class="px-3 py-1.5 border border-slate-200 text-slate-500 text-[10px] tracking-wider uppercase font-medium">
                  {t}
                </span>
              ))}
            </div>
            <a href={p.demo} class="text-[#3aa693] hover:text-[#2d8576] text-[10px] tracking-[0.2em] font-bold uppercase transition-colors">
              View the demo →
            </a>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>