---
// src/components/Skills.astro
---
<section id="skills" class="py-32 bg-[#fcfcfc]">
  <div class="max-w-6xl mx-auto px-6">
    
    <div class="mb-16">
      <p class="text-[11px] tracking-[0.3em] text-[#3aa693] font-bold uppercase mb-4">
        02 — Skills
      </p>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight">
        Technical Stack
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      
      <div class="flex flex-col gap-6">
        <h3 class="text-[10px] tracking-[0.2em] text-slate-400 font-bold uppercase border-b border-slate-100 pb-4">
          Core Languages
        </h3>
        <div class="flex flex-wrap gap-3">
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm font-medium">
            C# (.NET)
          </div>
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm">
            Python <span class="text-slate-300 mx-1">·</span> <span class="text-slate-400 text-xs italic">Learning</span>
          </div>
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm">
            JavaScript <span class="text-slate-300 mx-1">·</span> <span class="text-slate-400 text-xs italic">Learning</span>
          </div>
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm">
            HTML5 & CSS3 <span class="text-slate-300 mx-1">·</span> <span class="text-slate-400 text-xs italic">Learning</span>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-6">
        <h3 class="text-[10px] tracking-[0.2em] text-slate-400 font-bold uppercase border-b border-slate-100 pb-4">
          Frameworks & Tools
        </h3>
        <div class="flex flex-wrap gap-3">
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm font-medium">
            Flask
          </div>
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm font-medium">
            Socket.IO
          </div>
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm font-medium">
            Newtonsoft.Json
          </div>
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm font-medium">
            Unity
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-6">
        <h3 class="text-[10px] tracking-[0.2em] text-slate-400 font-bold uppercase border-b border-slate-100 pb-4">
          Specialized APIs
        </h3>
        <div class="flex flex-wrap gap-3">
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm font-medium">
            Autodesk Revit API
          </div>
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm font-medium">
            Google Model-Viewer
          </div>
          <div class="px-4 py-2 border border-slate-200 bg-white text-slate-700 text-sm font-medium">
            WebSockets
          </div>
        </div>
      </div>

    </div>
  </div>
</section>